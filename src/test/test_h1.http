@baseUrl = http://localhost:8080
@adminEmail = admin@example.com
@adminPassword = AdminPass123!
@memberName = Test Member
@memberPassword = MemberPass123!
@projectName = Demo Project
@taskTitle = Demo Task


### ──────────────────────────────────────────
### Group: Auth
### ──────────────────────────────────────────

### Auth: login admin
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "email": "{{adminEmail}}",
  "password": "{{adminPassword}}"
}

> {%
    client.global.set("adminToken", response.body.data.token);
    client.global.set("adminRefreshToken", response.body.data.refreshToken);
    client.global.set("adminUserId", response.body.data.userId);
    client.test("login admin returns token", function () {
        client.assert(response.status === 200, "Expected 200 OK");
        client.assert(!!response.body.data.token, "Expected access token");
    });
%}


### Auth: register member
POST {{baseUrl}}/api/auth/register
Content-Type: application/json

{
  "name": "{{memberName}}",
  "email": "member+{{$timestamp}}@example.com",
  "password": "{{memberPassword}}"
}

> {%
    client.global.set("memberEmail", response.body.data.email);
    client.test("register member returns email", function () {
        client.assert(response.status === 201, "Expected 201 Created");
        client.assert(!!response.body.data.email, "Expected email in response");
    });
%}


### Auth: login member
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "email": "{{memberEmail}}",
  "password": "{{memberPassword}}"
}

> {%
    client.global.set("memberToken", response.body.data.token);
    client.global.set("memberRefreshToken", response.body.data.refreshToken);
    client.global.set("memberUserId", response.body.data.userId);
    client.test("login member returns token", function () {
        client.assert(response.status === 200, "Expected 200 OK");
        client.assert(!!response.body.data.token, "Expected access token");
    });
%}


### Auth: refresh member token
POST {{baseUrl}}/api/auth/refresh
Content-Type: application/json

{
  "refreshToken": "{{memberRefreshToken}}"
}

> {%
    client.global.set("memberToken", response.body.data.token);
    client.test("refresh token returns new access token", function () {
        client.assert(response.status === 200, "Expected 200 OK");
        client.assert(!!response.body.data.token, "Expected access token");
    });
%}


### Auth: logout member
POST {{baseUrl}}/api/auth/logout
Authorization: Bearer {{memberToken}}
Content-Type: application/json

{
  "refreshToken": "{{memberRefreshToken}}"
}

> {%
    client.test("logout member", function () {
        client.assert(response.status === 200, "Expected 200 OK");
    });
%}


