Authorization: Bearer {{memberToken}}

> {%
    if (response.status === 200 && response.body && response.body.data && response.body.data.comments) {
        if (response.body.data.comments.length > 0) {
            client.global.set("commentId", response.body.data.comments[0].id);
        }
    }
    client.test("get task comments", function () {
        client.assert(response.status === 200, "Expected 200 OK");
    });
%}


